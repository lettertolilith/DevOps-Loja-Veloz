# Loja Veloz — variáveis de ambiente
# Copie este arquivo para .env antes de subir o ambiente:
#   cp .env.example .env

# Postgres
POSTGRES_PASSWORD=app

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Grafana
GRAFANA_PASSWORD=admin

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
